{
  "name": "drawspell-discord",
  "main": "src/worker.ts",
  "compatibility_date": "2026-03-01",
  "vars": {
    "NODE_ENV": "development",
  },
  "services": [
    {
      "binding": "SERVER",
      "service": "drawspell-server-development",
    },
  ],
  "env": {
    "production": {
      "name": "drawspell-discord-production",
      "vars": {
        "NODE_ENV": "production",
      },
      "services": [
        {
          "binding": "SERVER",
          "service": "drawspell-server-production",
        },
      ],
    },
  },
  "observability": {
    "enabled": false,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "invocation_logs": true,
    },
  },
  "routes": [
    {
      "pattern": "discord.drawspell.space",
      "custom_domain": true,
    },
  ],
}
